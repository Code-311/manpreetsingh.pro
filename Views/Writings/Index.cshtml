@model ListPageViewModel<Essay>
<section>
    <span class="meta-label">Index</span>
    <h1>@Model.Title</h1>
    <p>Essays on decisions, incentives, execution, and organizational delay.</p>
    @foreach (var item in Model.Items)
    {
        <article>
            <h3><a asp-action="Detail" asp-route-slug="@item.Slug">@item.Title</a></h3>
            <p>@item.Summary</p>
            <span class="meta-label">@item.ReadTimeMinutes min · @item.Category</span>
        </article>
    }
</section>
