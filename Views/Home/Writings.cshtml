@model WritingsPageViewModel
@{
    ViewData["Title"] = Model.Title;
}
<section class="page-intro section-reveal">
    <p class="kicker">Writings</p>
    <h1>@Model.Title</h1>
    <p>@Model.Intro</p>
</section>
<section>
    <div class="stack-list">
        @foreach (var item in Model.Items)
        {
            <article class="line-item" tabindex="0">
                <h2><a asp-controller="Home" asp-action="Writing" asp-route-slug="@item.Slug">@item.Title</a></h2>
                <p>@item.Summary</p>
                <div class="meta-row">
                    <span>@item.PublishedOn</span>
                    <span>@item.ReadTime</span>
                </div>
            </article>
        }
    </div>
</section>
