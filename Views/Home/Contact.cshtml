@model SimplePageViewModel
@{
    ViewData["Title"] = Model.Title;
}
<section class="page-intro section-reveal">
    <p class="kicker">Contact</p>
    <h1>@Model.Title</h1>
    <p>@Model.Intro</p>
</section>
<section>
    <ul class="plain-list">
        @foreach (var line in Model.Details)
        {
            <li>@line</li>
        }
    </ul>
</section>
