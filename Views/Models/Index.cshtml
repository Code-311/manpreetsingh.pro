@model ListPageViewModel<FrameworkModel>
<section>
    <span class="meta-label">Library</span>
    <h1>@Model.Title</h1>
    <p>Operational models for diagnosing where execution gets blocked.</p>
    @foreach (var item in Model.Items)
    {
        <article>
            <h3><a asp-action="Detail" asp-route-slug="@item.Slug">@item.Title</a></h3>
            <p>@item.Summary</p>
        </article>
    }
</section>
