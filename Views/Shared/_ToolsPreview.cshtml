@model HomePageViewModel
<section class="section-reveal" aria-labelledby="tools-preview-title">
    <div class="section-head">
        <p class="kicker">04</p>
        <h2 id="tools-preview-title">Tools preview</h2>
    </div>
    <div class="card-grid compact">
        @foreach (var item in Model.Tools)
        {
            <article class="info-card" tabindex="0">
                <h3><a asp-controller="Home" asp-action="Tool" asp-route-slug="@item.Slug">@item.Name</a></h3>
                <p>@item.Summary</p>
            </article>
        }
    </div>
</section>
