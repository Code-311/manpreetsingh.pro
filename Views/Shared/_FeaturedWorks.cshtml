@model HomePageViewModel
<section class="featured section-reveal" id="featured" aria-labelledby="featured-title">
    <div class="section-heading">
        <p class="micro-label">02</p>
        <h2 id="featured-title">Featured Work</h2>
    </div>
    <div class="work-grid">
        @foreach (var work in Model.FeaturedWorks)
        {
            <article class="work-card" tabindex="0">
                <div class="work-media-wrap">
                    <img src="@work.ImageUrl" alt="@work.AltText" class="work-media" loading="lazy" />
                </div>
                <div class="work-meta">
                    <p class="work-title">@work.Title</p>
                    <p class="work-description">@work.Description</p>
                    <div class="meta-row">
                        <span>@work.Category</span>
                        <span>@work.Year</span>
                    </div>
                </div>
            </article>
        }
    </div>
</section>
