@model HomePageViewModel
<section class="archive section-reveal" id="archive" aria-labelledby="archive-title">
    <div class="section-heading">
        <p class="micro-label">04</p>
        <h2 id="archive-title">Archive Index</h2>
    </div>
    <div class="archive-table" role="table" aria-label="Archive index">
        <div class="archive-head" role="rowgroup">
            <span role="columnheader">Code</span>
            <span role="columnheader">Module</span>
            <span role="columnheader">Discipline</span>
            <span role="columnheader">Year</span>
            <span role="columnheader">Status</span>
        </div>
        @foreach (var module in Model.ArchiveModules)
        {
            <div class="archive-row" role="row">
                <span>@module.Code</span>
                <span>@module.Label</span>
                <span>@module.Discipline</span>
                <span>@module.Year</span>
                <span>@module.Status</span>
            </div>
        }
    </div>
</section>
