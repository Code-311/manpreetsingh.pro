@model HomePageViewModel
<section class="section-reveal" aria-labelledby="selected-writings-title">
    <div class="section-head">
        <p class="kicker">03</p>
        <h2 id="selected-writings-title">Selected writings</h2>
    </div>
    <div class="stack-list">
        @foreach (var item in Model.SelectedWritings.Take(3))
        {
            <article class="line-item" tabindex="0">
                <h3><a href="/writings/@item.Slug">@item.Title</a></h3>
                <div class="meta-row">
                    <span>@item.PublishedOn</span>
                    <span>@item.ReadTime</span>
                </div>
            </article>
        }
    </div>
</section>
