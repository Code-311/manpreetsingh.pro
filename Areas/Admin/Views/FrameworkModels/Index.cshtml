@model IReadOnlyList<FrameworkModel>
<h2>Framework Models</h2><a asp-action="Create">Create</a>@foreach(var x in Model){<div>@x.Title <a asp-action="Edit" asp-route-id="@x.Id">Edit</a><form method="post" asp-action="Delete" asp-route-id="@x.Id">@Html.AntiForgeryToken()<button>Delete</button></form></div>}
